@model BestApp.Core.Entities.Project
@{
    ViewData["Title"] = "Yeni Proje Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="mb-4">
    <h2>Yeni Proje Ekle</h2>
    <p class="text-muted">Web sitesinde sergilenecek yeni bir peyzaj çalışması ekleyin.</p>
</div>

<div class="card shadow-sm col-md-8">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Project" asp-action="Create" method="post" enctype="multipart/form-data">
            
            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-bold">Proje Başlığı</label>
                <input asp-for="Title" class="form-control" placeholder="Örn: Villa Bahçesi Düzenlemesi" required />
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">Proje Detayı / Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Projede yapılan çalışmaları anlatın..."></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Proje Görseli (Zorunlu)</label>
                <input type="file" name="imageFile" class="form-control" accept="image/*" required />
                <div class="form-text">JPG, PNG veya WEBP formatında yatay resimler tercih edin.</div>
            </div>

            <div class="form-check form-switch mb-4 mt-3">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                <label asp-for="IsActive" class="form-check-label">Hemen Yayına Al (Aktif)</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Kaydet ve Yükle</button>
                <a href="/Admin/Project/Index" class="btn btn-light">İptal</a>
            </div>
        </form>
    </div>
</div>