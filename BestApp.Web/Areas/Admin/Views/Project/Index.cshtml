@model IEnumerable<BestApp.Core.Entities.Project>
@{
    ViewData["Title"] = "Projeler";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml"; // Master Page'i bağlıyoruz
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Best Peyzaj Projeleri</h2>
    <a href="/Admin/Project/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Yeni Proje Ekle</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Görsel</th>
                    <th>Proje Adı</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@item.ImageUrl" alt="@item.Title" class="img-thumbnail" style="width: 80px; height: 60px; object-fit: cover;" />
                        </td>
                        <td class="fw-bold">@item.Title</td>
                        <td>
                            @if(item.IsActive) { <span class="badge bg-success">Yayında</span> }
                            else { <span class="badge bg-secondary">Pasif</span> }
                        </td>
                        <td class="text-end">
                            <form asp-area="Admin" asp-controller="Project" asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu projeyi silmek istediğinize emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Sil</button>
                            </form>
                        </td>
                    </tr>
                }
                
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">Henüz sisteme eklenmiş bir proje bulunmuyor.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>