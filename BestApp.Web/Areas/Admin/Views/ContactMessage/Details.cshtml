@model BestApp.Core.Entities.ContactMessage
@{
    ViewData["Title"] = "Mesaj Detayı";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <h2>Mesaj İçeriği</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Gelen Kutusuna Dön</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3">
        <h4 class="mb-1">@Model.Subject</h4>
        <div class="text-muted small">
            <i class="bi bi-calendar3"></i> @Model.SentDate.ToString("dd MMMM yyyy, dddd - HH:mm")
        </div>
    </div>
    <div class="card-body p-4 bg-light">
        <div class="row mb-4 border-bottom pb-3">
            <div class="col-md-6">
                <span class="text-muted fw-bold d-block mb-1">Gönderen:</span>
                <span class="fs-5">@Model.Name</span>
            </div>
            <div class="col-md-6">
                <span class="text-muted fw-bold d-block mb-1">E-Posta Adresi:</span>
                <a href="mailto:@Model.Email" class="text-primary text-decoration-none">@Model.Email</a>
            </div>
        </div>
        
        <div>
            <span class="text-muted fw-bold d-block mb-2">Mesaj:</span>
            <p class="fs-6" style="line-height: 1.8; white-space: pre-wrap;">@Model.Message</p>
        </div>
    </div>
    <div class="card-footer bg-white py-3 text-end">
        <a href="mailto:@Model.Email?subject=Yanıt: @Model.Subject" class="btn btn-success">
            <i class="bi bi-reply"></i> E-Posta ile Yanıtla
        </a>
    </div>
</div>