@model IEnumerable<BestApp.Core.Entities.ContactMessage>
@{
    ViewData["Title"] = "Gelen Kutusu";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="mb-4">
    <h2><i class="bi bi-envelope-paper me-2"></i>Gelen Kutusu</h2>
    <p class="text-muted">Web siteniz üzerinden müşterilerin gönderdiği tüm mesajlar.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Durum</th>
                    <th>Gönderen</th>
                    <th>Konu</th>
                    <th>Tarih</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.IsRead ? "" : "bg-light")">
                        <td>
                            @if(item.IsRead) { 
                                <span class="badge bg-secondary">Okundu</span> 
                            } else { 
                                <span class="badge bg-danger">Yeni Mesaj</span> 
                            }
                        </td>
                        <td class="@(item.IsRead ? "" : "fw-bold")">
                            @item.Name <br>
                            <small class="text-muted fw-normal">@item.Email</small>
                        </td>
                        <td class="@(item.IsRead ? "" : "fw-bold")">@item.Subject</td>
                        <td>@item.SentDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                <i class="bi bi-eye"></i> Oku
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu mesajı kalıcı olarak silmek istediğinize emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-envelope-x" style="font-size: 2rem;"></i>
                            <p class="mt-2">Gelen kutunuz şu an boş.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>