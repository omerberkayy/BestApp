@model BestApp.Web.Models.HomeViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show text-center rounded-0 mb-0" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show text-center rounded-0 mb-0" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="bg-light py-5" style="background: linear-gradient(rgba(232, 245, 233, 0.8), rgba(232, 245, 233, 0.8)), url('https://images.unsplash.com/photo-1584622650111-993a426fbf0a?q=80&w=2070&auto=format&fit=crop') center/cover;">
    <div class="container py-5 my-5 text-center">
        <h1 class="display-4 fw-bold text-dark mb-4">Yeşilin ve Tasarımın Buluşma Noktası</h1>
        <p class="lead text-dark mb-5 mx-auto" style="max-width: 700px;">
            Modern peyzaj mimarisi ile bahçelerinizi ve yaşam alanlarınızı yeniden canlandırıyoruz.
        </p>
        <a href="#projelerimiz" class="btn btn-success btn-lg px-5 rounded-pill shadow-sm me-2">Projelerimiz</a>
        <a href="#iletisim" class="btn btn-outline-dark btn-lg px-5 rounded-pill shadow-sm">Bize Ulaşın</a>
    </div>
</section>

@if (Model.AboutInfo != null)
{
    <section class="container py-5 mt-4" id="hakkimizda">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                @if (!string.IsNullOrEmpty(Model.AboutInfo.ImageUrl))
                {
                    <img src="@Model.AboutInfo.ImageUrl" alt="Hakkımızda" class="img-fluid rounded-4 shadow" />
                }
                else
                {
                    <img src="https://images.unsplash.com/photo-1558904541-efa843a96f09?q=80&w=2000&auto=format&fit=crop" class="img-fluid rounded-4 shadow" alt="Hakkımızda Alternatif">
                }
            </div>
            <div class="col-lg-6">
                <h2 class="fw-bold mb-4">@Model.AboutInfo.Title</h2>
                <div class="bg-success mb-4" style="height: 3px; width: 60px;"></div>
                <p class="text-muted" style="line-height: 1.8;">
                    @Model.AboutInfo.Content
                </p>
            </div>
        </div>
    </section>
}

<section class="bg-light py-5 mt-5" id="hizmetlerimiz">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Neler Yapıyoruz?</h2>
            <div class="mx-auto bg-success mt-2 mb-4" style="height: 3px; width: 80px;"></div>
        </div>
        <div class="row g-4 justify-content-center">
            @foreach (var service in Model.Services)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm text-center p-4 rounded-4" style="transition: transform 0.3s ease;">
                        <div class="card-body">
                            <i class="bi @(string.IsNullOrEmpty(service.IconClass) ? "bi-check-circle" : service.IconClass) text-success mb-3" style="font-size: 3rem;"></i>
                            <h5 class="card-title fw-bold">@service.Title</h5>
                            <p class="card-text text-muted mt-3">@service.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="container py-5 mt-5" id="projelerimiz">
    <div class="text-center mb-5">
        <h2 class="fw-bold">Öne Çıkan Çalışmalarımız</h2>
        <div class="mx-auto bg-success mt-2 mb-4" style="height: 3px; width: 80px;"></div>
    </div>
    <div class="row g-4">
        @if (Model.Projects.Any())
        {
            foreach (var item in Model.Projects)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                        <div style="height: 250px; overflow: hidden;">
                            <img src="@item.ImageUrl" class="w-100 h-100" style="object-fit: cover;" alt="@item.Title">
                        </div>
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold">@item.Title</h5>
                            <p class="card-text text-muted">
                                @(string.IsNullOrEmpty(item.Description) ? "" : (item.Description.Length > 120 ? item.Description.Substring(0, 120) + "..." : item.Description))
                            </p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted">Henüz proje eklenmedi.</div>
        }
    </div>
</section>

<section class="container py-5 my-5" id="iletisim">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow rounded-4 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-5 bg-success text-white p-5 d-flex flex-column justify-content-center">
                        <h3 class="fw-bold mb-4">Bize Ulaşın</h3>
                        <p class="mb-4"><i class="bi bi-geo-alt-fill me-2"></i> Adana, Türkiye</p>
                        <p class="mb-4"><i class="bi bi-envelope-fill me-2"></i> info@bestpeyzaj.com</p>
                        <p><i class="bi bi-telephone-fill me-2"></i> +90 555 123 4567</p>
                    </div>
                    <div class="col-md-7 p-5">
                        <h4 class="fw-bold mb-4 text-dark">Mesaj Gönderin</h4>
                        
                        <form asp-controller="Home" asp-action="SendMessage" method="post">
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Adınız Soyadınız</label>
                                <input asp-for="ContactForm.Name" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">E-Posta Adresiniz</label>
                                <input asp-for="ContactForm.Email" type="email" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Konu</label>
                                <input asp-for="ContactForm.Subject" class="form-control" required />
                            </div>
                            <div class="mb-4">
                                <label class="form-label text-muted small fw-bold">Mesajınız</label>
                                <textarea asp-for="ContactForm.Message" class="form-control" rows="4" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-success w-100 fw-bold py-2">Mesajı Gönder</button>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>